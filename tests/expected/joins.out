> create table employees (emp_name text, emp_department uint4);
CREATE TABLE
> create table departments (dep_id uint4, dep_name text);
CREATE TABLE

> insert into employees values ('Rafferty',   31),
> ('Jones',      33),
> ('Heisenberg', 33),
> ('Robinson',   34),
> ('Smith',      34),
> ('Williams',   null);
INSERT 6

